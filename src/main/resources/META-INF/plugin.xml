<idea-plugin>
    <!-- 插件版本及作者信息 -->
    <id>com.jiuxiao.assistant</id>
    <name>DevAssistant</name>
    <version>1.0.0</version>
    <vendor email="yyh_skg@163.com" url="https://github.com/WuDaoJiuXiao">悟道九霄</vendor>

    <!-- 插件总体功能描述 -->
    <description><![CDATA[
    专门为Java后端开发者所服务的各种工作中的小工具合集，包括但不限于：
    + 对象转换
    + SQL处理
    + 加密解密
    ]]></description>

    <!-- 插件更新日志 -->
    <change-notes><![CDATA[

    ]]></change-notes>

    <actions>
        <!-- 提取方法参数转为JSON对象 -->
        <action id="ExtractMethodInfo"
                class="com.jiuxiao.assistant.action.ExtractMethodInfoAction"
                icon="/icon/DevLogo.svg"
                text="Converse To JSON"
                description="Extract all input parameters of the current method and build a default JSON request body">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <!-- 快速Mock请求体 -->
        <action id="ControlMock"
                class="com.jiuxiao.assistant.action.ControlMockAction"
                icon="/icon/DevLogo.svg"
                text="Mock Request Data"
                description="Quickly generate legitimate mock data for the current request method">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>

    <!-- 其他默认信息 -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- 系统通知组件 -->
        <notificationGroup displayType="BALLOON" id="DevAssistant.NotificationGroup"/>
        <!-- Mapper缓存服务 -->
        <projectService serviceImplementation="com.jiuxiao.assistant.service.MapperXmlCacheService"/>
        <!-- Mapper与XML互相跳转组件 -->
        <codeInsight.lineMarkerProvider language="JAVA"
                implementationClass="com.jiuxiao.assistant.provider.JavaMethodLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="XML"
                implementationClass="com.jiuxiao.assistant.provider.XmlIdLineMarkerProvider"/>
    </extensions>
</idea-plugin>